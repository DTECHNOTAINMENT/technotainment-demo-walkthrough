# Technotainment — environment configuration (.env.example)
# Copy to .env.local and fill in. NEVER commit real secrets.
# Grouped by the same domains as Admin → Connectors. Items marked (server) must stay server-side.

# ───────────────────────── core ─────────────────────────
NODE_ENV=development
# Provider mode: leave unset/"dev" to run on MOCKS (no real accounts needed — app fully works).
# Set LAUNCH_MODE=prod ONLY at go-live: it enforces that every "required for launch" provider
# in docs/INTEGRATIONS.md §4 has real keys, or the app refuses to start. See docs/INTEGRATIONS.md.
LAUNCH_MODE=dev
APP_URL=https://technotainment.fm
API_BASE_URL=https://api.technotainment.fm/v1
DATABASE_URL=postgresql://user:pass@localhost:5432/technotainment   # (server)
REDIS_URL=redis://localhost:6379                                    # (server) sessions, counters, rate-limit
SESSION_SECRET=                                                     # (server)

# CAST economy
CAST_PER_GBP=100                # 100 CAST = £1.00
PLATFORM_TAKE_RATE=0.12         # default creator fee (12%)
PAYOUT_HOLD_DAYS=7
PAYOUT_RUN_DAY=1                # auto-run monthly on the 1st

# ───────────────────── auth & identity ──────────────────
AUTH_PROVIDER=workos            # workos | auth0 | clerk
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=             # (server)
ADMIN_SSO_CONNECTION=           # staff SSO; enforce MFA on /admin
DISCORD_CLIENT_ID=              # social login + creator communities
DISCORD_CLIENT_SECRET=          # (server)
PERSONA_API_KEY=                # (server) KYC/KYB, age & ID verification
PERSONA_TEMPLATE_ID=

# ───────────────────────── payments ─────────────────────
# Stripe (primary acquiring, 3DS, Connect payouts)
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=              # (server)
STRIPE_WEBHOOK_SECRET=          # (server)
STRIPE_CONNECT_CLIENT_ID=
# Adyen (global acquiring + local methods)
ADYEN_API_KEY=                  # (server)
ADYEN_MERCHANT_ACCOUNT=
ADYEN_HMAC_KEY=                 # (server) webhook verify
# Wallets
APPLE_PAY_MERCHANT_ID=
APPLE_PAY_CERT=                 # (server)
GOOGLE_PAY_MERCHANT_ID=
PAYPAL_CLIENT_ID=               # PayPal + Venmo (US)
PAYPAL_CLIENT_SECRET=           # (server)
# Crypto (USDC top-up & payout)
CIRCLE_API_KEY=                 # (server)
USDC_PAYOUT_CHAIN=base          # base | polygon
# Mass payouts (creator earnings) + tax forms
TIPALTI_API_KEY=                # (server) or TROLLEY_*
# Mobile in-app purchase (selling CAST in iOS/Android apps — store policy)
APPLE_IAP_SHARED_SECRET=        # (server)
GOOGLE_PLAY_SERVICE_ACCOUNT=    # (server) JSON path/base64
# Bank linking
PLAID_CLIENT_ID=
PLAID_SECRET=                   # (server)

# ─────────────────────── risk & trust ───────────────────
SIFT_API_KEY=                   # (server) fraud & chargeback scoring
AUDIBLE_MAGIC_API_KEY=          # (server) music/content-ID (DMCA) — important for a music platform
HIVE_API_KEY=                   # (server) image/video moderation
OPENAI_API_KEY=                 # (server) AI text/chat moderation
# CSAM detection (required at scale): PhotoDNA / Thorn — request access separately

# ──────────────────────── media ─────────────────────────
MUX_TOKEN_ID=                   # live ingest, transcode, VOD
MUX_TOKEN_SECRET=               # (server)
MUX_WEBHOOK_SECRET=             # (server)
RTMP_INGEST_URL=rtmp://ingest.technotainment.fm/live
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=           # (server) CDN, stream edge, WAF
CLOUDFLARE_STREAM_KEY=          # (server)
LIVEKIT_API_KEY=                # co-watch "small rooms" (WebRTC)
LIVEKIT_API_SECRET=             # (server)
LIVEKIT_WS_URL=

# ──────────────────────── comms ─────────────────────────
SENDGRID_API_KEY=               # (server) transactional email
EMAIL_FROM=hello@technotainment.fm
TWILIO_ACCOUNT_SID=             # SMS OTP & alerts
TWILIO_AUTH_TOKEN=              # (server)
# Push (go-live alerts, drops)
FCM_SERVER_KEY=                 # (server) Android/web push
APNS_KEY_ID=                    # iOS push
APNS_TEAM_ID=
APNS_AUTH_KEY=                  # (server) .p8 path/base64
ONESIGNAL_APP_ID=               # optional unified push
ONESIGNAL_API_KEY=              # (server)

# ───────────────────────── tax ──────────────────────────
AVALARA_ACCOUNT_ID=             # VAT/sales tax + 1099-K / DAC7
AVALARA_LICENSE_KEY=            # (server)

# ──────────────────── data & analytics ──────────────────
SEGMENT_WRITE_KEY=              # product analytics pipeline
AMPLITUDE_API_KEY=              # optional deeper analytics
DATADOG_API_KEY=                # (server) APM, logs, alerting
SENTRY_DSN=                     # error tracking

# ─────────────────────── seo & growth ───────────────────
GOOGLE_SEARCH_CONSOLE_KEY=      # (server) index coverage, queries, sitemap submit
BING_WEBMASTER_API_KEY=         # (server) Bing index + IndexNow
INDEXNOW_KEY=                   # instant URL submission on publish
AHREFS_API_TOKEN=               # (server) rank tracking
BRANCH_KEY=                     # deep links / app indexing (universal links)
BRANCH_SECRET=                  # (server)
SANITY_PROJECT_ID=              # marketing site & blog CMS (programmatic SEO)
SANITY_TOKEN=                   # (server)
OG_IMAGE_SIGNING_KEY=           # (server) dynamic share-card service

# ─────────────────────── platform ───────────────────────
FEATURE_FLAG_PROVIDER=          # launchdarkly | statsig — Admin → Settings → flags
FEATURE_FLAG_SDK_KEY=           # (server)

# ─────────────────── infra / storage (AWS target) ───────
# Storage is S3-compatible (Cloudflare R2 in dev, AWS S3 in prod) — same StorageProvider adapter.
STORAGE_ENDPOINT=               # R2 endpoint in dev; leave blank to use AWS S3 default in prod
STORAGE_REGION=auto             # e.g. eu-west-2 on AWS
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=          # (server)
STORAGE_SECRET_ACCESS_KEY=      # (server)
# AWS production (only when migrating — see docs/INFRASTRUCTURE.md)
AWS_REGION=eu-west-2
AWS_SQS_QUEUE_URL=              # async jobs (QueueProvider)
# In prod, secrets are injected from AWS Secrets Manager / SSM — these vars stay the same names.
